<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================================================================== -->
    <!-- Typography — Pretendard Variable (Downloadable Font)                -->
    <!-- 한국어 lineSpacingMultiplier 1.4~1.5 (M3 영문 기본 대비 보강)         -->
    <!-- 면접 답변: "한국어 가독성 위해 Pretendard + line-height 보정"          -->
    <!-- ================================================================== -->

    <!-- Display Large — 거의 미사용, 마케팅 헤더용 -->
    <style name="TextAppearance.WalkMate.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Headline Large — 화면 메인 제목 (홈 인사말, 랭킹 타이틀) -->
    <style name="TextAppearance.WalkMate.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Headline Medium — 카드 메인 제목 -->
    <style name="TextAppearance.WalkMate.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Title Large — Card 헤더, 섹션 -->
    <style name="TextAppearance.WalkMate.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Title Medium — 카드 부제 -->
    <style name="TextAppearance.WalkMate.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Body Large — 본문 -->
    <style name="TextAppearance.WalkMate.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Body Medium — 보조 본문, 설명 -->
    <style name="TextAppearance.WalkMate.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Body Small — 캡션, 약관, 라벨 보조 -->
    <style name="TextAppearance.WalkMate.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Label Large — Button, Chip 텍스트 -->
    <style name="TextAppearance.WalkMate.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Label Medium — BottomNav 라벨 -->
    <style name="TextAppearance.WalkMate.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Step Counter — 큰 숫자 표시 (홈 7,812 보) -->
    <style name="TextAppearance.WalkMate.StepCounter" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/pretendard</item>
        <item name="fontFamily">@font/pretendard</item>
        <item name="android:textFontWeight">800</item>
        <item name="android:textSize">40sp</item>
        <item name="android:fontFeatureSettings">"tnum"</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

</resources>
