# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/walkmate

# --- JWT ---
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# --- Naver Cloud Platform Maps ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- Quota / Limits ---
NAVER_DAILY_QUOTA=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
